@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="app-wrapper">
    <header class="top-nav">
        <div class="nav-container">
            <div class="nav-brand" @onclick='() => Nav.NavigateTo("/")'>
                <span class="brand-logo">🤝</span>
                <span class="brand-name">팀찾사</span>
            </div>
            <nav class="nav-links">
                <a href="/" class="nav-link">게시판</a>
                @if (isLoggedIn)
                {
                    <a href="/my-activities" class="nav-link">내 활동</a>
                    <a href="/profile" class="nav-link">내 정보</a>
                    <button type="button" class="btn-login-sm" @onclick="HandleLogout">로그아웃</button>
                }
                else
                {
                    <button type="button" class="btn-login-sm" @onclick='() => Nav.NavigateTo("/login")'>로그인</button>
                }
            </nav>
        </div>
    </header>

    <main>
        <article>
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool isLoggedIn;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshLoginState();
        }
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = InvokeAsync(RefreshLoginState);
    }

    private async Task RefreshLoginState()
    {
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        var nextState = !string.IsNullOrWhiteSpace(token);

        if (isLoggedIn != nextState)
        {
            isLoggedIn = nextState;
            StateHasChanged();
        }
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        isLoggedIn = false;
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }
}

<style>
    .top-nav {
        background: white;
        border-bottom: 1px solid #e5e7eb;
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 0.75rem 0;
    }
    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .nav-brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }
    .brand-logo { font-size: 1.5rem; }
    .brand-name {
        font-size: 1.25rem;
        font-weight: 800;
        color: #111827;
    }
    .nav-links {
        display: flex;
        align-items: center;
        gap: 2rem;
    }
    .nav-link {
        text-decoration: none;
        color: #4b5563;
        font-weight: 600;
        font-size: 0.95rem;
    }
    .nav-link:hover { color: #3b82f6; }
    .btn-login-sm {
        background: #f3f4f6;
        border: 1px solid #d1d5db;
        padding: 0.4rem 1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
    }
    .btn-login-sm:hover {
        background: #e5e7eb;
    }
</style>
