@page "/post-detail"
@inject NavigationManager Nav

<div class="container">
    <div class="detail-layout">
        <!-- Main Content -->
        <main class="detail-main">
            <div class="card">
                <nav class="breadcrumb" @onclick='() => Nav.NavigateTo("/")' style="cursor:pointer;">게시판 > 프로젝트 모집</nav>
                <h1 class="detail-title">응용소프트웨어실습 3조 팀원 모집</h1>
                <div class="detail-meta">
                    <span>작성자: 문인호</span> | <span>조회수: 124</span> | <span>2시간 전</span>
                </div>
                
                <hr />

                <div class="detail-content">
                    <h3>프로젝트 개요</h3>
                    <p>본 프로젝트는 "팀원을 찾는 사람들"이라는 주제로, 에브리타임의 파편화된 정보를 통합하여 체계적인 팀 매칭 서비스를 구축하는 것을 목표로 합니다.</p>
                    
                    <h3>필요 기술 및 역량</h3>
                    <ul>
                        <li>C# 및 .NET 8.0 기반 클라이언트 개발</li>
                        <li>UI/UX 기획 및 디자인 감각</li>
                        <li>Git/Github을 통한 협업 경험</li>
                    </ul>

                    <h3>모집 인원</h3>
                    <p>프론트엔드 1명, 백엔드 1명 추가 모집합니다.</p>
                </div>
            </div>
        </main>

        <!-- Sidebar (Status) -->
        <aside class="detail-sidebar">
            <div class="card status-card">
                <h3>모집 현황 (2/4)</h3>
                <div class="member-list">
                    <div class="member-item">
                        <div class="member-info">
                            <span class="member-name">문인호 (조장)</span>
                            <span class="tag-mini">#C#</span>
                        </div>
                    </div>
                    <div class="member-item">
                        <div class="member-info">
                            <span class="member-name">강은우</span>
                            <span class="tag-mini">#SQL</span>
                        </div>
                    </div>
                    <div class="member-placeholder">남은 자리 (2)</div>
                </div>
                <button class="btn-primary full-width" @onclick="HandleApply">지원하기</button>
            </div>
        </aside>
    </div>
</div>

@code {
    private void HandleApply()
    {
        // 실제로는 여기서 API를 호출하여 지원 정보를 저장합니다.
        // 현재는 시뮬레이션으로 바로 활동 관리 페이지로 이동합니다.
        Nav.NavigateTo("/my-activities");
    }
}

<style>
    .detail-layout {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 2rem;
    }
    .breadcrumb {
        font-size: 0.85rem;
        color: #9ca3af;
        margin-bottom: 1rem;
    }
    .detail-title {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
    .detail-meta {
        font-size: 0.9rem;
        color: #6b7280;
        margin-bottom: 1.5rem;
    }
    .detail-content h3 {
        margin-top: 2rem;
        font-size: 1.25rem;
    }
    .detail-content p, .detail-content li {
        line-height: 1.7;
        color: #374151;
    }
    .status-card h3 {
        margin-bottom: 1.5rem;
    }
    .member-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .member-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .member-name {
        font-weight: 600;
        display: block;
    }
    .member-placeholder {
        border: 2px dashed #e5e7eb;
        padding: 1rem;
        text-align: center;
        border-radius: 0.5rem;
        color: #9ca3af;
        font-size: 0.9rem;
    }
    .full-width {
        width: 100%;
        padding: 1rem;
    }
</style>
