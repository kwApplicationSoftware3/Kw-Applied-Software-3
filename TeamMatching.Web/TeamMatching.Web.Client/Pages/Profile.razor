@page "/profile"

<div class="container">
    <div class="profile-header card">
        <div class="profile-info">
            <div class="avatar">M</div>
            <div>
                <h2>문인호 님</h2>
                <p>소프트웨어학부 | 2022203002</p>
                <div class="tag-cloud">
                    <span class="tag">#C#</span>
                    <span class="tag">#.NET</span>
                    <span class="tag">#UX/UI</span>
                </div>
            </div>
        </div>
        <button class="btn-secondary">프로필 수정</button>
    </div>

    <div class="profile-stats grid-2">
        <!-- Trust/Review Stats -->
        <div class="card">
            <h3>상호 평가 요약</h3>
            <p class="section-desc">이전 프로젝트 팀원들이 평가한 신뢰도입니다.</p>
            <div class="stat-item">
                <span class="stat-label">협업 신뢰도</span>
                <div class="progress-bar"><div class="progress" style="width: 95%"></div></div>
                <span class="stat-value">95%</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">기술 기여도</span>
                <div class="progress-bar"><div class="progress" style="width: 88%"></div></div>
                <span class="stat-value">88%</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">의사소통</span>
                <div class="progress-bar"><div class="progress" style="width: 92%"></div></div>
                <span class="stat-value">92%</span>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="card">
            <h3>최근 참여 프로젝트</h3>
            <ul class="activity-list">
                <li>
                    <strong>응용소프트웨어실습 3조</strong>
                    <span>역할: 조장, UI 기획</span>
                    <span class="status-done">진행중</span>
                </li>
                <li>
                    <strong>알고리즘 스터디</strong>
                    <span>역할: 팀원</span>
                    <span class="status-done">완료</span>
                </li>
            </ul>
        </div>
    </div>
</div>

<style>
    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }
    .profile-info {
        display: flex;
        gap: 2rem;
        align-items: center;
    }
    .avatar {
        width: 100px;
        height: 100px;
        background: #3b82f6;
        color: white;
        font-size: 3rem;
        font-weight: 800;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
    }
    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
    .section-desc {
        color: #6b7280;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }
    .stat-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }
    .stat-label {
        width: 100px;
        font-size: 0.9rem;
        font-weight: 600;
    }
    .progress-bar {
        flex: 1;
        height: 8px;
        background: #f3f4f6;
        border-radius: 4px;
        overflow: hidden;
    }
    .progress {
        height: 100%;
        background: #3b82f6;
    }
    .stat-value {
        font-weight: 700;
        color: #3b82f6;
        width: 40px;
    }
    .activity-list {
        list-style: none;
        padding: 0;
    }
    .activity-list li {
        padding: 1rem 0;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .status-done {
        font-size: 0.75rem;
        background: #eff6ff;
        color: #1d4ed8;
        padding: 0.125rem 0.5rem;
        border-radius: 4px;
        width: fit-content;
    }
    .btn-secondary {
        background: white;
        border: 1px solid #d1d5db;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
    }
</style>
