@page "/register"
@inject NavigationManager Nav

<div class="container">
    <div class="auth-card">
        <h2 class="auth-title">회원가입</h2>
        <p class="auth-subtitle">팀 매칭 서비스에 오신 것을 환영합니다.</p>

        <form class="auth-form" @onsubmit="HandleRegister">
            <div class="form-group">
                <label for="email">이메일</label>
                <input type="email" id="email" class="form-control" placeholder="example@university.ac.kr" required />
            </div>
            
            <div class="form-group">
                <label for="password">비밀번호</label>
                <input type="password" id="password" class="form-control" placeholder="비밀번호를 입력하세요" required />
            </div>

            <div class="form-group">
                <label for="passwordConfirm">비밀번호 확인</label>
                <input type="password" id="passwordConfirm" class="form-control" placeholder="비밀번호를 다시 입력하세요" required />
            </div>

            <div class="form-group">
                <label>관심 기술 스택 (다중 선택 가능)</label>
                <div class="tag-selection">
                    @foreach (var tag in availableTags)
                    {
                        <span class="tag @(selectedTags.Contains(tag) ? "active" : "")" 
                              @onclick="() => ToggleTag(tag)">
                            @tag
                        </span>
                    }
                </div>
            </div>

            <button type="submit" class="btn-primary full-width mt-2">가입 완료</button>
            
            <div class="auth-links">
                <span>이미 계정이 있으신가요?</span>
                <a href="/login" class="link-primary">로그인</a>
            </div>
        </form>
    </div>
</div>

@code {
    private List<string> availableTags = new() { "#C#", "#.NET", "#Java", "#Spring", "#React", "#Vue", "#Python", "#AI", "#Design", "#Figma" };
    private HashSet<string> selectedTags = new();

    private void ToggleTag(string tag)
    {
        if (selectedTags.Contains(tag))
        {
            selectedTags.Remove(tag);
        }
        else
        {
            selectedTags.Add(tag);
        }
    }

    private void HandleRegister()
    {
        // TODO: 실제 데이터베이스 저장 로직 추가
        // 가입 완료 후 로그인 페이지로 이동
        Nav.NavigateTo("/login");
    }
}

