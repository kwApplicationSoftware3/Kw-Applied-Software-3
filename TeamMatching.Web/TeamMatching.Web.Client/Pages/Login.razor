@page "/login"
@using TeamMatching.Shared.DTOs
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">로그인</h2>
        <p class="auth-subtitle">팀 매칭 서비스를 계속 이용하려면 로그인해주세요.</p>

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">이메일</label>
                <InputText id="email" type="email" class="form-input" @bind-Value="loginModel.Email" placeholder="email@example.com" />
                <ValidationMessage For="@(() => loginModel.Email)" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="password">비밀번호</label>
                <InputText id="password" type="password" class="form-input" @bind-Value="loginModel.Password" placeholder="비밀번호를 입력하세요" />
                <ValidationMessage For="@(() => loginModel.Password)" class="text-danger" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <button type="submit" class="btn-primary full-width" disabled="@isSubmitting">
                @(isSubmitting ? "로그인 중..." : "로그인")
            </button>
        </EditForm>

        <div class="auth-footer">
            아직 계정이 없으신가요? <a href="/signup">회원가입</a>
        </div>
    </div>
</div>

@code {
    private readonly LoginRequest loginModel = new();
    private string? errorMessage;
    private bool isSubmitting;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

            if (response.IsSuccessStatusCode && result?.IsSuccess == true && !string.IsNullOrWhiteSpace(result.AccessToken))
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.AccessToken);
                Nav.NavigateTo("/");
                return;
            }

            errorMessage = result?.Message ?? "로그인에 실패했습니다.";
        }
        catch (Exception ex)
        {
            errorMessage = "서버 통신 중 오류가 발생했습니다: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        background-color: var(--bg-gray, #f9fafb);
    }
    .auth-card {
        background: var(--white, #ffffff);
        padding: 2.5rem;
        border-radius: 1rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border: 1px solid var(--border, #e5e7eb);
        width: 100%;
        max-width: 450px;
    }
    .auth-title {
        font-size: 1.75rem;
        font-weight: 800;
        text-align: center;
        margin-bottom: 0.5rem;
        color: var(--text-main, #111827);
    }
    .auth-subtitle {
        text-align: center;
        color: var(--text-muted, #6b7280);
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }
    .form-group {
        margin-bottom: 1.25rem;
    }
    .form-group label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    .form-input {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 0.5rem;
        font-size: 1rem;
        transition: border-color 0.2s;
    }
    .form-input:focus {
        outline: none;
        border-color: var(--primary, #3b82f6);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    .full-width {
        width: 100%;
        padding: 0.875rem;
        font-size: 1rem;
        margin-top: 1rem;
    }
    .auth-footer {
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.875rem;
        color: var(--text-muted, #6b7280);
    }
    .auth-footer a {
        color: var(--primary, #3b82f6);
        text-decoration: none;
        font-weight: 600;
    }
    .auth-footer a:hover {
        text-decoration: underline;
    }
    .text-danger {
        color: #ef4444;
        display: block;
        font-size: 0.8rem;
        margin-top: 0.25rem;
    }
    .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        padding: 0.75rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }
</style>
