@page "/create-post"
@inject NavigationManager Nav

<div class="container">
    <div class="form-card">
        <header class="form-header">
            <button class="btn-back" @onclick="GoBack">← 돌아가기</button>
            <h2 class="form-title">새 모집글 작성</h2>
        </header>

        <form class="post-form" @onsubmit="HandleSubmit">
            <!-- Project Title -->
            <div class="form-group">
                <label for="title">프로젝트 제목</label>
                <input type="text" id="title" class="form-control" placeholder="예: [응용소프트웨어실습] 3조 팀원 모집합니다" required />
            </div>

            <!-- Category / Position -->
            <div class="form-row">
                <div class="form-group flex-1">
                    <label for="category">프로젝트 분야</label>
                    <select id="category" class="form-control">
                        <option>전공 프로젝트</option>
                        <option>개인 토이 프로젝트</option>
                        <option>공모전/대외활동</option>
                        <option>기타</option>
                    </select>
                </div>
                <div class="form-group flex-1">
                    <label for="memberCount">모집 인원 (명)</label>
                    <input type="number" id="memberCount" class="form-control" min="1" max="10" value="4" />
                </div>
            </div>

            <!-- Required Skills (Tags) -->
            <div class="form-group">
                <label>필요 기술 스택 (클릭하여 선택)</label>
                <div class="tag-selection">
                    @foreach (var tag in availableTags)
                    {
                        <span class="tag @(selectedTags.Contains(tag) ? "active" : "")" 
                              @onclick="() => ToggleTag(tag)">
                            @tag
                        </span>
                    }
                </div>
            </div>

            <!-- Description -->
            <div class="form-group">
                <label for="description">상세 설명</label>
                <textarea id="description" class="form-control text-area" 
                          placeholder="프로젝트 목표, 진행 방식, 우대 사항 등을 상세히 적어주세요." required></textarea>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-secondary" @onclick="GoBack">취소</button>
                <button type="submit" class="btn-primary">등록하기</button>
            </div>
        </form>
    </div>
</div>

@code {
    private List<string> availableTags = new() { "#C#", "#.NET", "#Java", "#Spring", "#React", "#Vue", "#Python", "#AI", "#Design", "#Figma", "#SQL" };
    private HashSet<string> selectedTags = new();

    private void ToggleTag(string tag)
    {
        if (selectedTags.Contains(tag))
            selectedTags.Remove(tag);
        else
            selectedTags.Add(tag);
    }

    private void HandleSubmit()
    {
        // TODO: 서버 API 호출하여 DB에 저장
        // 등록 완료 후 대시보드로 이동
        Nav.NavigateTo("/");
    }

    private void GoBack()
    {
        Nav.NavigateTo("/");
    }
}

<style>
    .form-card {
        max-width: 800px;
        margin: 3rem auto;
        padding: 2.5rem;
        background: var(--white, #ffffff);
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 1rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .form-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid var(--border, #e5e7eb);
        padding-bottom: 1rem;
    }
    .btn-back {
        background: none;
        border: none;
        color: var(--text-muted, #6b7280);
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
    }
    .btn-back:hover {
        color: var(--primary, #3b82f6);
    }
    .form-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
    }
    .post-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .form-row {
        display: flex;
        gap: 1.5rem;
    }
    .flex-1 { flex: 1; }
    .form-group label {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text-main, #111827);
    }
    .form-control {
        padding: 0.875rem 1rem;
        border: 1px solid var(--border, #e5e7eb);
        border-radius: 0.5rem;
        font-size: 1rem;
    }
    .text-area {
        min-height: 250px;
        resize: vertical;
    }
    .tag-selection {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        background: #f9fafb;
        padding: 1rem;
        border-radius: 0.5rem;
        border: 1px dashed var(--border, #e5e7eb);
    }
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        margin-top: 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border, #e5e7eb);
    }
    .btn-secondary {
        background: #f3f4f6;
        border: 1px solid #d1d5db;
        padding: 0.75rem 2rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
    }
    .btn-secondary:hover { background: #e5e7eb; }
</style>
